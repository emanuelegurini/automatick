# Automatick - Backend Configuration
# Copy this file to .env and configure the values below
# NEVER commit .env to version control

# =============================================================================
# PRODUCT MODE
# =============================================================================
AUTOMATICK_MODE=headless
ENABLE_FRONTEND=false
ENABLE_JIRA=false
ENABLE_FRESHDESK=true

# =============================================================================
# REQUIRED: Freshdesk Integration
# =============================================================================
# Your Freshdesk domain. Either the bare domain or full URL is accepted.
# Example: your-company.freshdesk.com
FRESHDESK_DOMAIN=your-company.freshdesk.com

# Freshdesk API key used to fetch tickets and post private notes.
FRESHDESK_API_KEY=your-freshdesk-api-key

# Shared secret that Freshdesk must send in X-Automatick-Webhook-Secret.
FRESHDESK_WEBHOOK_SECRET=change-this-shared-secret

# =============================================================================
# OPTIONAL: Jira Integration (set ENABLE_JIRA=true to deploy)
# =============================================================================
# Your Jira instance URL
# Example: https://mycompany.atlassian.net
JIRA_DOMAIN=https://your-company.atlassian.net

# Your Atlassian account email
JIRA_EMAIL=your-email@company.com

# Jira API token
# How to create:
# 1. Go to: https://id.atlassian.com/manage-profile/security/api-tokens
# 2. Click "Create API token"
# 3. Name it "Automatick"
# 4. Copy the generated token
JIRA_API_TOKEN=your-api-token-here

# Default Jira project key for ticket creation
# Find in your Jira project settings (e.g., "PROJ", "OPS", "TASK")
JIRA_PROJECT_KEY=YOUR-PROJECT-KEY

# =============================================================================
# REQUIRED: Bedrock Model (1 field - has default)
# =============================================================================
# Amazon Bedrock model ID for agent inference
# Recommended: us.amazon.nova-pro-v1:0
# Alternative: us.amazon.nova-lite-v1:0 (faster, cheaper)
MODEL=us.amazon.nova-pro-v1:0

# Maximum output tokens for agent responses (controls verbosity and speed)
# Supervisor default: 2048, Specialist agents default: 1024
# Lower values = faster responses but may truncate complex answers
MAX_TOKENS=2048

# =============================================================================
# OPTIONAL: Backend Container Architecture
# =============================================================================
# Use linux/arm64 + ARM64 when deploying from an ARM/Graviton bastion.
# Use linux/amd64 + X86_64 when deploying from an x86_64 bastion.
BACKEND_DOCKER_PLATFORM=
BACKEND_CPU_ARCHITECTURE=

# =============================================================================
# OPTIONAL: Advanced Features (2 fields - can skip)
# =============================================================================
# Bedrock Knowledge Base ID for RAG-based troubleshooting
# Leave empty to disable KB feature
# How to create: https://docs.aws.amazon.com/bedrock/latest/userguide/knowledge-base.html
BEDROCK_KNOWLEDGE_BASE_ID=

# Email for unresolved ticket notifications
# Leave empty to disable notifications
UNRESOLVED_TICKET_EMAIL=

# =============================================================================
# AUTO-POPULATED: Infrastructure Values
# DO NOT EDIT - These are set automatically by deploy.sh after CDK deployment
# =============================================================================
# AgentCore Resources (Step 4 & Step 5)
SUPERVISOR_RUNTIME_ARN=
MEMORY_ID=
GATEWAY_ARN=
GATEWAY_URL=

# Cognito Authentication (Step 5)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# Frontend URL for CORS (Step 12)
FRONTEND_URL=

# MCP Server Runtime ARNs (Step 6)
CLOUDWATCH_MCP_ARN=
AWS_API_MCP_ARN=
AWS_KNOWLEDGE_MCP_ARN=

# =============================================================================
# OPTIONAL: Remediation Configuration
# =============================================================================
# Detection mode for triggering remediation workflows
# 'llm' = LLM-based intent classification (detects alarms, security findings, cost anomalies)
# 'regex' = Original regex-based alarm detection (CloudWatch alarms only)
REMEDIATION_DETECTION_MODE=llm

# Guard validation mode for remediation steps
# 'demo' = Lenient validation (current behavior, blocks only destructive operations)
# 'production' = Strict validation (requires dry-run, checks blast radius, reversibility)
GUARD_MODE=demo

# Verification loop settings (alarm state check after remediation)
VERIFICATION_MAX_RETRIES=3
VERIFICATION_RETRY_DELAY_SECONDS=30

# A2A Specialist Runtime ARNs (Step 8-9  enables direct routing, bypasses Supervisor)
# These are written by deploy.sh Step 9 and propagated to ECS via CDK Step 9.8
CLOUDWATCH_A2A_ARN=
SECURITY_A2A_ARN=
COST_A2A_ARN=
ADVISOR_A2A_ARN=
JIRA_A2A_ARN=
KNOWLEDGE_A2A_ARN=
