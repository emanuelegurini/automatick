# Frontend Environment Variables (Vite)
# ==========================================
# 
# ⚠️  AUTO-GENERATED FILE - DO NOT EDIT MANUALLY
# 
# This file is completely overwritten by deploy.sh during deployment.
# All values are automatically extracted from CDK outputs.json after
# infrastructure deployment completes.
#
# If you need to modify frontend configuration:
# 1. Update the CDK stack definitions in infrastructure/cdk/
# 2. Run ./deploy.sh to regenerate this file with new values
#
# For local development, deploy.sh will create frontend/.env with:
# ==========================================

# AWS Cognito Configuration (from CDK outputs)
VITE_AWS_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=your-user-pool-id
VITE_COGNITO_CLIENT_ID=your-client-id

# API Configuration (from CDK outputs)
VITE_API_BASE_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/prod/api/v1
VITE_WS_URL=wss://your-api-id.execute-api.us-east-1.amazonaws.com/prod/api/v1/ws
